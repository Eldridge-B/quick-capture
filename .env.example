# Quick Capture — Environment Variables
#
# Copy this file to .env and fill in the values.
# Expo client vars must be prefixed with EXPO_PUBLIC_.

# ── Expo App (client-side) ──────────────────────────────────
EXPO_PUBLIC_API_BASE=https://quick-capture-worker.quick-capture-worker.workers.dev
EXPO_PUBLIC_CAPTURE_SECRET=your-shared-secret-here

# ── Cloudflare Worker (set via `wrangler secret put`) ───────
# These are NOT read from .env — they're here for reference.
DEEPGRAM_API_KEY=your-deepgram-key
NOTION_API_KEY=your-notion-key
ANTHROPIC_API_KEY=your-anthropic-key
CAPTURE_SECRET=your-shared-secret-here
